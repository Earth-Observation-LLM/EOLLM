## Output schema

Return a **single JSON object**. Use only words for values; no numeric counts or ranges. Use directions only for locations.

```json
{
  "image_info": {
    "visibility_issues": ["clouds", "haze", "smoke", "shadows", "tilt", "low_resolution", "occluded"],
    "sun_shadow_notes": "short shadows toward northeast, moderate haze",
    "overall_confidence": "low | mid | high"
  },
  "scene_summary": "brief description of dominant surfaces, structure types, and overall layout character",
  "observations": [
    {
      "category": "free text category, for example bus_terminal or railyard or rooftop_garden",
      "subtype": "optional free text",
      "is_novel_category": "yes | no",
      "location": "north | northeast | east | southeast | south | southwest | west | northwest | center",
      "status": "present | uncertain | occluded | absent",
      "confidence": "low | mid | high",
      "quantity": "single | few | several | many | dense | sparse | continuous",
      "scale": "very small | small | medium | large | very large",
      "evidence": [
        "concise visual cue",
        "another concise visual cue"
      ],
      "attributes": {
        "footprint": "rectangular | square | linear | L-shape | T-shape | irregular | unknown",
        "roof_type": "flat | pitched | sawtooth | arched | mixed | unknown",
        "roof_color": "white | grey | red | brown | metallic | mixed | unknown",
        "height_class": "low-rise | mid-rise | high-rise | unknown",
        "rooftop_features": ["solar_panels", "HVAC", "water_tanks", "skylights", "green_roof", "helipad"],
        "surface": "asphalt | concrete | gravel | bare_soil | grass | shrub | tree_canopy | water | mixed | unknown",
        "condition": "new | good | patched | cracked | eroded | stained | flooded | unknown",
        "transport_features": ["median", "lane_markings", "sidewalks", "crosswalks", "bus_lane", "bike_lane", "platform", "loading_bays", "bridge", "roundabout"],
        "boundary": "wall | fence | hedge | none | unknown",
        "spatial_relation": "adjacent_to | within | along | surrounding | connected_to | overlapping | none"
      }
    }
  ],
  "ambiguities": [
    {
      "item": "free text name for the unclear feature",
      "location": "direction or center",
      "reason": "what makes it unclear",
      "status": "uncertain | occluded",
      "confidence": "low | mid",
      "evidence": ["cue one", "cue two"]
    }
  ],
  "meta": {
    "taxonomy": "open",
    "notes": "mention any features noticed that fall outside the checklist"
  }
}
```

